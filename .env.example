# === Telegram MTProto API ===
# Получить на https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Строка сессии (заполняется автоматически после первого входа)
TELEGRAM_SESSION=

# === OpenRouter AI ===
# Ключ на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Модель (список: https://openrouter.ai/models)
# Бесплатные варианты: meta-llama/llama-3.1-8b-instruct:free
# Платные (качественнее): anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-5.2

# === Персонаж ===
# Как AI должен себя вести при ответах
SYSTEM_PROMPT=Ты — я. Отвечай на сообщения кратко, по-человечески, от первого лица. Не раскрывай, что ты AI.

# Сколько последних сообщений хранить как контекст (по умолчанию 20)
MAX_HISTORY=20
